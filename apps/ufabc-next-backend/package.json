{
  "name": "ufabc-next-backend",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "services:up": "docker compose up -d",
    "build": "turbo run build",
    "tsc": "turbo run tsc --parallel",
    "start": "turbo run start",
    "start:watch": "turbo run start:watch",
    "test": "turbo run test",
    "lint": "pnpm dlx ultracite fix",
    "deps-check": "pnpm dlx taze -r",
    "db:teachers:preview": "cd apps/core && tsx src/scripts/db/maintenance/deduplicate-teachers-preview.ts",
    "db:teachers:backup": "cd apps/core && tsx src/scripts/db/maintenance/backup-teachers.ts",
    "db:teachers:deduplicate": "cd apps/core && tsx src/scripts/db/maintenance/deduplicate-teachers.ts",
    "db:teachers:rollback": "cd apps/core && tsx src/scripts/db/maintenance/rollback-teachers.ts"
  },
  "devDependencies": {
    "oxfmt": "^0.22.0",
    "oxlint": "^1.37.0",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "ultracite": "^7.0.4"
  },
  "engines": {
    "node": "^24",
    "pnpm": "^9"
  },
  "packageManager": "pnpm@9.15.9"
}
