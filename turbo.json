{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", "**/.env", "**/.env.*"],
  "tasks": {
    "build": {
      "env": [
        "VITE_APP_ENV",
        "VITE_APP_BASE_URL",
        "VITE_API_BASE_URL",
        "VITE_PARSER_API_BASE_URL",
        "VITE_MIXPANEL_TOKEN"
      ],
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:staging": {
      "env": [
        "VITE_APP_ENV",
        "VITE_APP_BASE_URL",
        "VITE_API_BASE_URL",
        "VITE_PARSER_API_BASE_URL",
        "VITE_MIXPANEL_TOKEN"
      ],
      "dependsOn": ["^build:staging"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "lint:fix": {},
    "tsc": {},
    "test": {},
    "test:watch": {
      "cache": false
    },
    "dev": {
      "env": [
        "VITE_APP_ENV",
        "VITE_APP_BASE_URL",
        "VITE_API_BASE_URL",
        "VITE_PARSER_API_BASE_URL",
        "VITE_MIXPANEL_TOKEN"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
